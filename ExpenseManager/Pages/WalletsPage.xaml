<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ExpenseManager.Pages"
             xmlns:models="clr-namespace:ExpenseManager.UIModels;assembly=ExpenseManager.UIModels"
             x:Class="ExpenseManager.Pages.WalletsPage"
             x:DataType="pages:WalletsPage"
             Title="Wallets">

    <CollectionView
        ItemsSource="{Binding Wallets}"
        Margin="10"
        SelectionMode="Single"
        SelectionChanged="WalletSelected">

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:WalletUIModel">
                <Border
                    Stroke="#4AA3FF"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#EAF4FF"
                    Padding="12"
                    Margin="0,10">

                    <VerticalStackLayout>
                        <Label
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="Black">
                            <MultiBinding StringFormat="{}{0} (Total: {1})">
                                <Binding Path="Name" />
                                <Binding Path="TotalAmountDesc" />
                            </MultiBinding>
                        </Label>

                        <Label
                            Text="{Binding Valuta, Converter={StaticResource EnumToDisplayName}}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>

                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>