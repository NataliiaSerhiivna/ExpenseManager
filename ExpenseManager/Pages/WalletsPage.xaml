<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ExpenseManager.DTOModels.Wallets;assembly=ExpenseManager.DTOModels"
             xmlns:vm="clr-namespace:ExpenseManager.ViewModels"
             x:Class="ExpenseManager.Pages.WalletsPage"
             x:DataType="vm:WalletsViewModel"
             Title="Wallets"
             IsEnabled="{Binding IsNotBusy}">

    <Grid RowDefinitions="Auto,*,Auto">

        <VerticalStackLayout Grid.Row="0"
                             Padding="10"
                             Spacing="10">

            <SearchBar Placeholder="Search wallets"
                       Text="{Binding SearchText}" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10">

                <Picker Grid.Column="0"
                        Title="Filter by currency"
                        ItemsSource="{Binding ValutaFilters}"
                        SelectedItem="{Binding SelectedValutaFilter}" />

                <Picker Grid.Column="1"
                        Title="Sort wallets"
                        ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSortOption}" />
            </Grid>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Wallets}"
                        Margin="10"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedWallet}"
                        SelectionChangedCommand="{Binding LoadWalletCommand}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:WalletListDTO">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem Text="Delete"
                                           BackgroundColor="Red"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletsViewModel}}, Path=DeleteWalletCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border Stroke="#7E57C2"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#F3E8FF"
                                Padding="12"
                                Margin="0,10">

                            <VerticalStackLayout>
                                <Label FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#2E1F5E"
                                       HorizontalOptions="Center">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} (Balance: {1})">
                                            <Binding Path="Name" />
                                            <Binding Path="TotalAmount" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>

                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10"
                                      Margin="0,10,0,0">
                                    <Button Grid.Column="0"
                                            Text="Edit Wallet"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletsViewModel}}, Path=EditWalletCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Grid.Column="1"
                                            Text="Delete Wallet"
                                            BackgroundColor="Red"
                                            TextColor="White"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletsViewModel}}, Path=DeleteWalletCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>

                                <Label Text="{Binding Valuta, Converter={StaticResource EnumToDisplayName}}"
                                       HorizontalOptions="Center"
                                       TextColor="#4B3A78" />
                            </VerticalStackLayout>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                Text="Create new Wallet"
                Command="{Binding AddWalletCommand}"
                Margin="10"
                HorizontalOptions="Center"
                BackgroundColor="#7E57C2"
                TextColor="White"
                CornerRadius="12"
                Padding="16,10" />

        <BoxView IsVisible="{Binding IsBusy}"
                 BackgroundColor="Gray"
                 Opacity="0.2"
                 InputTransparent="False"
                 Grid.RowSpan="3" />

        <ActivityIndicator Color="Magenta"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Grid.RowSpan="3" />
    </Grid>
</ContentPage>