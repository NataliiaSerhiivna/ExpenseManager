<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:ExpenseManager.DTOModels.Transactions;assembly=ExpenseManager.DTOModels"
             xmlns:vm="clr-namespace:ExpenseManager.ViewModels"
             x:Class="ExpenseManager.Pages.WalletDetailsPage"
             x:DataType="vm:WalletDetailsViewModel"
             Title="Wallet Details">

    <Grid RowDefinitions="Auto,*">

        <Border Stroke="#7E57C2"
                StrokeThickness="2"
                StrokeShape="RoundRectangle 12"
                BackgroundColor="#F3E8FF"
                Padding="12"
                Margin="10,10,10,0">

            <VerticalStackLayout>
                <Label FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#2E1F5E"
                       HorizontalOptions="Center"
                       Text="{Binding CurrentWallet.Name}" />

                <Label Text="{Binding CurrentWallet.Valuta, Converter={StaticResource EnumToDisplayName}}"
                       HorizontalOptions="Center"
                       TextColor="#4B3A78" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Transactions}"
                        Margin="10"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:TransactionListDTO">
                    <Border Stroke="#4AA3FF"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#EAF4FF"
                            Padding="12"
                            Margin="0,10">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletDetailsViewModel}}, Path=LoadTransactionCommand}"
                                CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout>
                            <Label FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="Black"
                                   HorizontalOptions="Center">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} ({1})">
                                        <Binding Path="Description" />
                                        <Binding Path="Amount" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>

                            <Label Text="{Binding Category, Converter={StaticResource EnumToDisplayName}}"
                                   HorizontalOptions="Center"
                                   TextColor="#1E3A5F" />

                            <Label Text="{Binding Timestamp, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                   HorizontalOptions="Center"
                                   TextColor="#4A6078"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>